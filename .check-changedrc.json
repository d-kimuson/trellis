{
  "$schema": "./node_modules/check-changed/config-schema.json",
  "defaults": {
    "changed": "untracked,unstaged,staged,branch:main",
    "target": "all"
  },
  "checks": {
    "swiftlint": {
      "pattern": "\\.swift$",
      "command": "swiftlint lint --quiet --force-exclude {{CHANGED_FILES}}",
      "group": "lint"
    },
    "build": {
      "pattern": "\\.swift$",
      "command": "make build",
      "group": "build"
    },
    "test": {
      "pattern": "\\.swift$",
      "command": "make test",
      "group": "test"
    }
  }
}
